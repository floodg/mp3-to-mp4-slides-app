{
  "name": "mp3-to-mp4-slides-app",
  "version": "0.1.0",
  "description": "Desktop app to convert MP3 to MP4 with slides",
  "main": "dist/main.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc && node -e \"require('fs').copyFileSync('src/renderer.html','dist/renderer.html')\"",
    "start": "npm run build && electron .",
    "dev": "tsc -w"
  },
  "dependencies": {
    "electron": "^35.1.4",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}
